# Fixtures de parsers : pages réelles enregistrées (.html/.json), à VERSIONNER
# malgré les règles *.json / *.html ci-dessus (offline, rejouées par les tests).
!tests/fixtures/**

# Sidecars de fraîcheur des certifs (meta) : à VERSIONNER malgré *.json
# (convention brut+clean : le clean et sa meta accompagnent la source).
!data/certifications/**/*.meta.json
!data/certifications/**/metadata.json

