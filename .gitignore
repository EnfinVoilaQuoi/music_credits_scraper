# Script, Fix & Driver
src/scripts/
# scripts/ : ignoré par défaut (one-shot, diagnostics), SAUF les outils maintenus.
# `scripts/*` (et non `scripts/`) pour que les négations fonctionnent, et pour que
# Black/Ruff (qui respectent le gitignore) voient les fichiers maintenus.
scripts/*
# Maintenance DB
!scripts/check_database_status.py
!scripts/check_duplicates.py
!scripts/merge_duplicates.py
!scripts/restore_from_backup.py
!scripts/migrate_snep_to_csv.py
!scripts/check_observations.py
# Tests / santé des sources
!scripts/warm_cf_profile.py
!scripts/capture_fixtures.py
!scripts/check_sources_health.py
# Outils sources actifs (contournements documentés dans CLAUDE.md)
!scripts/bpmfinder_login.py
!scripts/bpmfinder_diagnose.py
!scripts/sonoteller_worklist.py
!scripts/run_brma.ps1
# Dataviz / export studio
!scripts/bubble_prod.py
